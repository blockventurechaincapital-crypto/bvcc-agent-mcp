# --- BVCC Agent Wallet MCP server configuration ---
# Two ways to provide these:
#   (A) Inline in your MCP host config's `env` block (simplest).
#   (B) In a dedicated env file (RECOMMENDED for the key): keep the secret OUT of
#       the host config (which gets shared/synced/screenshotted). Point the server
#       at it with BVCC_ENV_FILE=/abs/path/agent.env, then `chmod 600` that file
#       and keep it outside any cloud-synced folder. Host env vars still win over
#       the file. Note: this is not encryption — the file is plaintext on disk;
#       its value is reducing accidental-leak surface.
# The private key is used locally to sign and is NEVER transmitted anywhere.

# The agent EOA private key (0x + 64 hex chars). This is the key you generated
# for the agent; its public address is what you authorized in the BVCC dashboard.
AGENT_PRIVATE_KEY=0x...

# The BVCC Agent Wallet address this agent operates.
WALLET_ADDRESS=0x...

# DEFAULT chain id, used when a tool call omits `network`. Supported:
#   1      = Ethereum
#   56     = BNB Chain (BSC)
#   42161  = Arbitrum One
#   8453   = Base
#   421614 = Arbitrum Sepolia (testnet)
# This server is multi-network: every tool also takes an optional `network` arg
# (chain id or name), so you can tell the LLM "swap on bsc" without restarting.
# The wallet address is the same on every chain (CREATE2); the agent must be
# authorized on each chain you use.
CHAIN_ID=42161

# Optional RPC overrides. RPC_URL is the default chain's RPC; RPC_URL_<chainId>
# overrides a specific chain. Any chain without an override uses a public default.
#
# FAILOVER: each value may list SEVERAL RPCs separated by commas. They're tried in
# order (a downed RPC fails over to the next), and the chain's public default is
# always appended last as a safety net — useful for an always-on bot.
# RPC_URL=https://arb1.arbitrum.io/rpc,https://arbitrum.llamarpc.com   # default chain, 2 RPCs
# RPC_URL_1=https://eth.llamarpc.com,https://rpc.ankr.com/eth          # Ethereum failover
# RPC_URL_56=https://bsc-dataseed.binance.org,https://bsc-dataseed1.defibit.io
# RPC_URL_42161=https://arb1.arbitrum.io/rpc

# Optional: expose ONLY read/simulate tools (no fund-moving writes). Default off.
# BVCC_MCP_READONLY=true

# Optional: OPT-IN "Receipt Required" — keep writes available but require a
# verifiable human authorization receipt (bound to recipient/amount/token) on
# every fund-moving tool, or the tx is refused before broadcast. Default off, so
# leaving this unset is byte-identical to before. See README "Receipt Required".
# BVCC_MCP_RECEIPTS=true
# Production: pin the issuer SPKI key(s) you trust (comma-separated). Without
# this, the gate accepts a receipt's own inline key (integrity only — demo).
# BVCC_MCP_RECEIPT_KEYS=
# Optional: path to a custom action-risk manifest (defaults to ./agent-actions.json).
# BVCC_MCP_ACTIONS_FILE=
